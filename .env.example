# Taptree Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# REQUIRED - App will not start without these
# ===========================================

# MongoDB connection string
# Get from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=

# NextAuth secret key (REQUIRED for production)
# Generate with: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
AUTH_SECRET=

# ===========================================
# OPTIONAL - Auto-configured by Vercel
# ===========================================

# The canonical URL of your site
# Vercel sets this automatically, only needed for local development
# AUTH_URL=http://localhost:3000

# Node environment (set automatically)
# NODE_ENV=development
